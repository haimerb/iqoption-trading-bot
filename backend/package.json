{
  "name": "iqoption-trading-bot-backend",
  "version": "1.0.0",
  "description": "Bot de trading para IQ Option - Backend REST API",
  "main": "src/server.js",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --coverage",
    "test:api": "jest tests/api --coverage",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "bull": "^4.12.2",
    "ioredis": "^5.3.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.6.2",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "ws": "^8.16.0",
    "crypto-js": "^4.2.0",
    "joi": "^17.11.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "compression": "^1.7.4",
    "uuid": "^9.0.1",
    "@tensorflow/tfjs-node": "^4.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "@jest/globals": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
